# Django Core Settings
DEBUG=True
SECRET_KEY=django-insecure-your-secret-key-here
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Database Configuration (PostgreSQL + PostGIS)
# Format: postgis://user:password@host:port/dbname
DATABASE_URL=postgis://uber_user:uber_pass@db:5432/uber_logistica

# Cache and Message Broker (Redis)
REDIS_URL=redis://redis:6379/0

# Security (JWT)
JWT_SECRET=your-jwt-signing-secret-here

# Maps Provider (Google Maps, Mapbox, HERE, or mock)
MAPS_PROVIDER=mock
MAPS_API_KEY=your-maps-api-key-here

# Payments Provider (Stripe, Asaas, or mock)
PAYMENT_PROVIDER=mock
PAYMENT_API_KEY=your-payment-api-key-here

# AI / LLM Configuration (OpenAI, Gemini, Claude, or mock)
LLM_PROVIDER=mock
LLM_API_KEY=your-llm-api-key-here

# Email Configuration
EMAIL_HOST=mailhog
EMAIL_PORT=1025
EMAIL_USER=""
EMAIL_PASSWORD=""
DEFAULT_FROM_EMAIL=no-reply@uberlogistica.com
